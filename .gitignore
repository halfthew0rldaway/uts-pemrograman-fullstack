# ============================================================
# .gitignore — PT Digital Nusantara HR System
# ============================================================

# ─── Environment Variables ───────────────────────────────────
# JANGAN commit file .env asli — gunakan .env.example sebagai template
backend/.env
vuestic-admin/.env

# ─── Dependencies ────────────────────────────────────────────
node_modules/
backend/node_modules/
vuestic-admin/node_modules/

# ─── Build Output ────────────────────────────────────────────
vuestic-admin/dist/
vuestic-admin/.vite/

# ─── File Uploads (user-generated content) ───────────────────
backend/uploads/photos/*
backend/uploads/imports/*
# Pertahankan struktur direktori
!backend/uploads/photos/.gitkeep
!backend/uploads/imports/.gitkeep

# ─── Logs ────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
backend/logs/

# ─── OS & Editor Junk ────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ─── IDE / Editor ────────────────────────────────────────────
.vscode/settings.json
.vscode/launch.json
.idea/
*.swp
*.swo
*~

# ─── TypeScript ──────────────────────────────────────────────
*.tsbuildinfo
vuestic-admin/tsconfig.tsbuildinfo

# ─── Cache ───────────────────────────────────────────────────
.cache/
.parcel-cache/
vuestic-admin/.eslintcache
vuestic-admin/.stylelintcache

# ─── Testing ─────────────────────────────────────────────────
coverage/
.nyc_output/

# ─── Misc ────────────────────────────────────────────────────
*.pem
*.key
*.cert

# ─── Vuestic Boilerplate (tidak relevan) ─────────────────────
vuestic-admin/.github/
vuestic-admin/.husky/
vuestic-admin/CONTRIBUTING.md
vuestic-admin/LICENSE
