# ============================================================
# Frontend Environment Variables — Template
# Salin file ini menjadi .env dan isi nilainya
# cp .env.example .env
# JANGAN commit file .env ke version control
# ============================================================

# Base URL API — gunakan /api untuk Vite proxy di development
# Vite akan meneruskan semua request /api ke http://localhost:5000/api
# Di production, ganti dengan URL backend yang sebenarnya:
# VITE_API_BASE_URL=https://api.ptdigitalnusantara.com/api
VITE_API_BASE_URL=/api

# Google Tag Manager (opsional, kosongkan jika tidak digunakan)
VITE_APP_GTM_KEY=
VITE_APP_GTM_ENABLED=false

# Build info (opsional)
VITE_APP_BUILD_VERSION=1.0.0
